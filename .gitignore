# Dependencies
node_modules/

# Next.js build output
.next/
out/

# TypeScript build artifacts
tsconfig.tsbuildinfo

# Environment files — never commit secrets
.env
.env.local
.env.*.local

# Runtime data — re-generated by `npm run seed`. The committed
# data/seed/ snapshot stays; only the live runtime files are excluded.
data/*.json

# Logs and runtime debris
*.log
npm-debug.log*
.DS_Store
