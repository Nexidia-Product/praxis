# Praxis environment variables.
#
# Copy this file to `.env.local` and edit as needed. Every variable is
# optional unless explicitly marked Required; uncomment only the ones
# you need to set.
#
# .env.local is read by Next.js at build and runtime. Do not check it
# into version control — the .gitignore excludes it.

# -----------------------------------------------------------------------------
# Database + Authentication (Supabase) — Required
# -----------------------------------------------------------------------------
#
# Find these values in your Supabase project → Project Settings → API.
# Real values live in .env.local (gitignored), NOT in this file. Do not
# paste actual keys here — .env.example is committed to version control,
# and the service_role key in particular bypasses Row-Level Security and
# grants full read/write access to the database. Treat it like a password.

# NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Anon (public) key — safe to expose to the browser; rate-limited and
# scoped by RLS policies. Used by sign-in / sign-out / password reset.
# NEXT_PUBLIC_SUPABASE_ANON_KEY="paste-anon-key-here"

# Service-role (secret) key — SERVER-ONLY. Never reference from client
# components and never commit. Used by API routes and migration scripts
# for admin-level operations.
# SUPABASE_SERVICE_ROLE_KEY="paste-service-role-key-here"

# Public canonical URL of the app. Surfaces in invite + password-reset
# emails so the recovery link redirects back here. Defaults to
# http://localhost:3000 when unset.
# NEXT_PUBLIC_SITE_URL="https://praxis.yourcompany.com"

# -----------------------------------------------------------------------------
# Seed (one-time)
# -----------------------------------------------------------------------------

# Override the default admin email + name BEFORE running `npm run seed`.
# Identity is owned by Supabase Auth — there is no password to set here;
# the user sets one via the recovery link printed by
# `npm run migrate:auth-users -- --confirm`.
# IIM_ADMIN_EMAIL="admin@yourcompany.com"
# IIM_ADMIN_NAME="Your Name"

# Path to the source spreadsheet. Defaults to ./Tiger_Team_Projects.xlsx,
# falling back to the bundled snapshot under data/seed/.
# IIM_SEED_SOURCE="/path/to/Tiger_Team_Projects.xlsx"

# -----------------------------------------------------------------------------
# Email delivery for per-event notifications (Resend) — Optional
# -----------------------------------------------------------------------------
#
# Supabase handles AUTH emails (invites, password reset) via its own
# templates. Per-event NOTIFICATION emails (TaskAssigned, ProjectBlocked,
# etc.) still go through Resend. When RESEND_API_KEY is unset, those
# notifications are logged to stdout instead of sent — fine for
# development. To enable real delivery, sign up at https://resend.com,
# create an API key, and paste it here.
# RESEND_API_KEY="re_yourapikeyhere"

# The "From" address. Resend lets you use onboarding@resend.dev without
# domain verification — useful for first-time testing. For real
# deployments, verify your domain in the Resend dashboard and set
# this to something like "Praxis <notifications@yourcompany.com>".
# RESEND_FROM="Praxis <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# Scheduled jobs (Vercel Cron)
# -----------------------------------------------------------------------------

# Shared secret between Vercel Cron and the daily notification sweep
# route (/api/admin/notifications/sweep). Vercel sends
# `Authorization: Bearer <CRON_SECRET>` on every cron POST; the route
# rejects unauthenticated calls unless they carry this header.
#
# Required for production. Generate with: openssl rand -base64 32
# Local dev: leave unset — the route falls back to the session-based
# admin permission check for the manual "Run sweep now" button.
# CRON_SECRET="paste-a-32-byte-random-string-here"

# -----------------------------------------------------------------------------
# AI features (AWS Bedrock) — Local dev only
# -----------------------------------------------------------------------------
#
# AI features (complexity scoring, priority recommendation, idea
# overlap) are gated behind AI_ENABLED. They are intentionally OFF
# in production because Bedrock authentication today goes through
# IAM Identity Center / SSO, and Vercel cannot run `aws sso login`
# to refresh credentials. Set AI_ENABLED=true ONLY in .env.local.
# AI_ENABLED=true

# AWS SDK profile name. The profile must already exist in
# ~/.aws/config — run `aws configure sso` once to create it. The
# SDK reads `sso_region`, `sso_start_url`, `sso_account_id`,
# `sso_role_name` from that profile and refreshes credentials from
# the SSO cache transparently.
#
# Re-auth when the cache expires (typically once per workday) with:
#   aws sso login --profile bedrock
#
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY /
# AWS_SESSION_TOKEN here. Those env vars take precedence over the
# profile in the SDK's default credential chain, and they're static
# point-in-time exports — setting them would defeat auto-refresh.
# AWS_PROFILE=bedrock

# Bedrock service region. The SDK reads BEDROCK_REGION first,
# AWS_REGION second, defaulting to us-east-1. Pick whichever region
# is BOTH in the org's region-whitelist policy (the IAM policy named
# `Policy-DenyAllOutsideWhitelistedRegion` or similar) AND where the
# team has Bedrock Model Access granted. The SSO region in the
# profile is independent.
# BEDROCK_REGION=us-east-1
